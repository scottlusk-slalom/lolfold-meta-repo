{
  "version": "1.0",
  "description": "Platform validation rules. Add rules here without modifying validate-gp.sh.",
  "rules": [
    {
      "id": "GP-001",
      "name": "_loop-config.yaml present and valid",
      "category": "harness",
      "check": {
        "type": "validate_script",
        "script": "scripts/validate-loop-config.sh",
        "target_arg": "{target}/_loop-config.yaml"
      },
      "remediation": "Run: ./scripts/generate-loop-config.sh --target <repo-path>"
    },
    {
      "id": "GP-002",
      "name": "AGENTS.md present (AOS harness readiness)",
      "category": "harness",
      "check": {
        "type": "file_exists",
        "path": "AGENTS.md"
      },
      "remediation": "Run /init-repo on the target repo to generate AGENTS.md"
    },
    {
      "id": "GP-003",
      "name": "Repo name ≤25 characters",
      "category": "repository",
      "check": {
        "type": "repo_name_max_length",
        "max": 25
      },
      "remediation": "Rename the repository to ≤25 characters (kebab-case)"
    }
  ]
}
